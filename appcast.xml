                <item>
            <title>Shelf 1.3</title>
            <pubDate>Fri, 05 Jun 2026 21:32:10 -0400</pubDate>
            <sparkle:version>5</sparkle:version>
            <sparkle:shortVersionString>1.3</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[Fixes: (1) Dragging a file out of the shelf no longer duplicates it inside — the main shelf window is now browse/drag-out only, and new files come in via the floating drop zone. (2) Screenshot drops are reliable again — the ingest path now falls back to fulfilling file promises when the file URL points to a placeholder, which fixes screenshots silently failing to add.]]></description>
            <enclosure
                url="https://github.com/DeveshSt/Shelf/releases/download/v1.3/Shelf-1.3.zip"
                sparkle:edSignature="JWB5BmvYFCDMNSdUCDprFJ0oKs8uvF+91yR7sHpYBwWUn1sUV0MOB4QZlcjWNLoYy8LnzgBeUrYZ9NgnkcevCQ=="
                length="1697755"
                type="application/octet-stream"/>
        </item>
