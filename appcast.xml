                <item>
            <title>Shelf 1.2</title>
            <pubDate>Wed, 03 Jun 2026 22:03:04 -0400</pubDate>
            <sparkle:version>4</sparkle:version>
            <sparkle:shortVersionString>1.2</sparkle:shortVersionString>
            <sparkle:minimumSystemVersion>13.0</sparkle:minimumSystemVersion>
            <description><![CDATA[Fix: dragging a file out of the shelf no longer creates a duplicate inside it. The floating drop zone also no longer appears when you're dragging from the shelf itself — only when you're dragging something new in from another app.]]></description>
            <enclosure
                url="https://github.com/DeveshSt/Shelf/releases/download/v1.2/Shelf-1.2.zip"
                sparkle:edSignature="TI/8YkXqrh7P25pO1cOdW1g46VwBiY2e45DBcOC7pWgdhQ7/cKZzss7GEsnPmM9euW9ptxVzrhj+vQ7Ctc9UBA=="
